<script>
import { Quotation } from '@/views/pages/eset/trackers2/utils/classQuotation'
import logoUrl from './tbSellerToolAssets/fromFig/logo.png'
import heroUrl from './tbSellerToolAssets/fromFig/hero.png'
import photoStripUrl from './tbSellerToolAssets/fromFig/photo-strip.png'

export default {
  name: 'TbSellerQuotation',
  data() {
    return {
      q: new Quotation(),
      assets: {
        logo: logoUrl,
        hero: heroUrl,
        photoStrip: photoStripUrl,
      },
    }
  },
  computed: {
    specRows() {
      const p = this.q.proposed_tracker_solution
      return [
        { label: 'Product', value: p.product },
        { label: 'Drive system', value: p.drive_system },
        { label: 'Control & communication', value: p.control_communication },
        { label: 'Power source', value: p.power_source },
        { label: 'Design wind speed', value: p.design_wind_speed },
        { label: 'Corrosion protection', value: p.corrosion_protection },
        { label: 'Post type & embedment depth', value: p.post_type_embedments_depth },
        { label: 'Module power', value: p.module_power },
        { label: 'Module / strings', value: p.module_no_strings },
        { label: 'Operation features', value: p.operation_features },
        { label: 'Slope available', value: p.slope_available },
        { label: 'Rotation features', value: p.rotation_features },
        { label: 'Design life', value: p.design },
      ]
    },
  },
}
</script>

