<script>
import echarts from 'echarts/lib/echarts'
import { getToken } from '@/utils/auth'
import { getBomUnitPrice, getAdjustCostPrice, getTrackerCategroyA,
  getTrackerTotal,getTrackerTotalByDesigner,getTrackerTotalByMy } from '@/views/pages/eset/trackers2/utils/classPlan.js'

export default {
  name: 'TrackerResult',
  data() {
    return {
      // 设置图片的URL
      imageSrc: '', // 图片的路径
      imageVisible: false, // 控制图片是否显示
      partImgTop: 0,  //图片出现位置
      partImgLeft: 0,
      thePartName: '',
      dwgSrc: '', // 图纸图片的路径
      dwgVisible: false, // 控制图片是否显示
      imgObj: {},  //用于保存图片数据
      thePartCode: ''
    }
  },
  computed:{
    //单个tracker的瓦数
    trackerCapacity(){
      return this.trackerObj.solar_num * this.trackerObj.pv_capacity
    },
    //获取设计师的调价信息
    designerAdjustPriceDetail(){
      let adjustDetails = {}
      for (const item of this.planPriceAdjust) {
        if(item.who_adjust === this.designer){
          adjustDetails = item.adjust_price_details
          break
        }
      }
      return adjustDetails
    },

    //获取我的调价信息
    myAdjustPriceDetail(){
      let adjustDetails = {}
      for (const item of this.planPriceAdjust) {
        if(item.who_adjust === this.name){
          adjustDetails = item.adjust_price_details
          break
        }
      }
      return adjustDetails
    },

    //原始的bom表内容不完善，比如没有单价表等
    newBoms(){
      let nbom = this.trackerObj.resultList.bom1;
      for (const b of nbom) {
        b._unitPrice = getBomUnitPrice(b.priceMethod,b.costPrice,b.unitWeight);  //获取材料单价
        b._totalPrice = b._unitPrice * b.amount;  //获取材料单价

        //设计师调后的价格fdsa
        b._designerCostPrice = b.costPrice;
        b._designerUnitPrice = b._unitPrice;
        b._designerTotalPrice = b._totalPrice;
        if(this.planPriceAdjust.length > 0){
          let myAdjustDetails = {}
          for (const item of this.planPriceAdjust) {
            if(item.who_adjust === this.designer){
              myAdjustDetails = item.adjust_price_details
              break
            }
          }
          let theCost = getAdjustCostPrice(b,myAdjustDetails);
          b._designerCostPrice = theCost;
          b._designerUnitPrice = getBomUnitPrice(b.priceMethod,theCost,b.unitWeight),  //获取材料单价,
          b._designerTotalPrice = b._designerUnitPrice * b.amount;
        }

        //我调后的价格
        b._myCostPrice = b.costPrice;
        b._myUnitPrice = b._unitPrice;
        b._myTotalPrice = b._totalPrice;
        if(this.planPriceAdjust.length > 0){
          let myAdjustDetails = {}
          for (const item of this.planPriceAdjust) {
            if(item.who_adjust === this.myName){
              myAdjustDetails = item.adjust_price_details
              break
            }
          }
          let theCost = getAdjustCostPrice(b,myAdjustDetails);
          b._myCostPrice = theCost;
          b._myUnitPrice = getBomUnitPrice(b.priceMethod,theCost,b.unitWeight),  //获取材料单价,
          b._myTotalPrice = b._myUnitPrice * b.amount;
        }
      }

      return nbom
    },

    //分表
    tableData1(){
      const items = ['04','05','06','07','08']
      return this.divideBom(items)
    },
    tableData2(){
      const items = ['09']
      return this.divideBom(items)
    },
    tableData3(){
      const items = ['01','02','03','20']
      return this.divideBom(items)
    },
    tableDataErr(){
      return this.trackerObj.resultList.bomErr;
    },
  },

  methods: {

    tableData_totalWeight(data){
      return data.reduce((a,b)=>a+b.totalWeight,0)
    },
    tableData_totalPrice(data){
      return data.reduce((a,b)=>a+b._totalPrice,0)
    },
    tableData_designerTotalPrice(data){
      return data.reduce((a,b)=>a+b._designerTotalPrice,0)
    },




    //将表格分为三类，主材，紧固件，机械电气
    divideBom(items){
      let boms = [];
      this.newBoms.forEach(b => {
        if (items.includes(b.priceId.substring(0,2))) {
          boms.push(b)
        }
      })
      return boms
    },
    //显示小图
    showImage(e) {
      // console.log('this.thePartCode', this.thePartCode)
      this.thePartCode = e.target.innerText
      this.dwgVisible = false
      if (this.imgObj[this.thePartCode] !== undefined && this.imgObj[this.thePartCode].indexOf('not be found') == -1) {
        this.imageSrc = this.imgObj[this.thePartCode]
      } else {
        this.imageSrc = this.imgObj['imgNotFound']
      }
      this.imageVisible = true
    },

    showEChartClass1() {
      let myChart = echarts.init(document.getElementById('class1'))
      // let d = this.statistics[0].categroyA //按成本价统计
      let d = getTrackerCategroyA(this.newBoms,{})
      let tp = getTrackerTotal(this.newBoms)  //单个支架的总价
      // 指定图表的配置项和数据
      var option = {
        title: {
          text: '【系统】支架总价:' + tp.toFixed(2) + '(元)', // 这里设置标题的文本
          left: 'center',  // 标题位置居中
          // 可以在这里添加更多的标题样式配置，比如：
          textStyle: {
            color: '#337c99', // 标题文字颜色
            fontSize: 20   // 标题文字大小
          }
        },
        tooltip: {
          trigger: 'item'
        },
        legend: {
          orient: 'vertical',
          left: 'left',
          top: 'middle'
        },
        series: [
          {
            name: 'Access From',
            type: 'pie',
            radius: ['40%', '70%'],
            avoidLabelOverlap: false,
            itemStyle: {
              borderRadius: 10,
              borderColor: '#fff',
              borderWidth: 2
            },
            label: {
              show: false,
              position: 'center'
            },
            emphasis: {
              label: {
                show: true,
                fontSize: 40,
                fontWeight: 'bold'
              }
            },
            labelLine: {
              show: false
            },
            data: [
              {
                value: d.drivesSystem.toFixed(2),
                name: '减速机 ' + d.drivesSystem.toFixed(2) + ` [${(100 * d.drivesSystem / tp).toFixed(1)}%]`
              },
              {
                value: d.controlSystem.toFixed(2),
                name: '控制系统 ' + d.controlSystem.toFixed(2) + ` [${(100 * d.controlSystem / tp).toFixed(1)}%]`
              },
              {
                value: d.damper.toFixed(2),
                name: '阻尼 ' + d.damper.toFixed(2) + ` [${(100 * d.damper / tp).toFixed(1)}%]`
              },
              { value: d.post.toFixed(2), name: '立柱 ' + d.post.toFixed(2) + `[${(100 * d.post / tp).toFixed(1)}%]` },
              {
                value: d.torqueTube.toFixed(2),
                name: '主梁 ' + d.torqueTube.toFixed(2) + ` [${(100 * d.torqueTube / tp).toFixed(1)}%]`
              },
              {
                value: d.purlin.toFixed(2),
                name: '檩条 ' + d.purlin.toFixed(2) + ` [${(100 * d.purlin / tp).toFixed(1)}%]`
              },
              {
                value: d.stampingParts.toFixed(2),
                name: '冲压件 ' + d.stampingParts.toFixed(2) + ` [${(100 * d.stampingParts / tp).toFixed(1)}%]`
              },
              {
                value: d.castingPart.toFixed(2),
                name: '铸造件 ' + d.castingPart.toFixed(2) + ` [${(100 * d.castingPart / tp).toFixed(1)}%]`
              },
              {
                value: d.fastners.toFixed(2),
                name: '紧固件 ' + d.fastners.toFixed(2) + ` [${(100 * d.fastners / tp).toFixed(1)}%]`
              },
              {
                value: d.others.toFixed(2),
                name: '其它 ' + d.others.toFixed(2) + ` [${(100 * d.others / tp).toFixed(1)}%]`
              }
            ]
          }
        ]
      }
      myChart.setOption(option)// 使用刚指定的配置项和数据显示图表。spareParts
    },

    showEChartClass2() {
      let myChart = echarts.init(document.getElementById('class2'))
      let d = getTrackerCategroyA(this.newBoms,this.designerAdjustPriceDetail)  //计算各成分价
      let tp = getTrackerTotalByDesigner(this.newBoms)  //单个支架的总价
      // 指定图表的配置项和数据
      var option = {
        title: {
          text: '【设计师:'+this.designer+'】支架总价:' + tp.toFixed(2) + '(元)', // 这里设置标题的文本
          left: 'center',  // 标题位置居中
          // 可以在这里添加更多的标题样式配置，比如：
          textStyle: {
            color: '#337c99', // 标题文字颜色
            fontSize: 20   // 标题文字大小
          }
        },
        tooltip: {
          trigger: 'item'
        },
        legend: {
          orient: 'vertical',
          left: 'left',
          top: 'middle'
        },
        series: [
          {
            name: 'Access From',
            type: 'pie',
            radius: ['40%', '70%'],
            avoidLabelOverlap: false,
            itemStyle: {
              borderRadius: 10,
              borderColor: '#fff',
              borderWidth: 2
            },
            label: {
              show: false,
              position: 'center'
            },
            emphasis: {
              label: {
                show: true,
                fontSize: 40,
                fontWeight: 'bold'
              }
            },
            labelLine: {
              show: false
            },
            data: [
              {
                value: d.drivesSystem.toFixed(2),
                name: '减速机 ' + d.drivesSystem.toFixed(2) + ` [${(100 * d.drivesSystem / tp).toFixed(1)}%]`
              },
              {
                value: d.controlSystem.toFixed(2),
                name: '控制系统 ' + d.controlSystem.toFixed(2) + ` [${(100 * d.controlSystem / tp).toFixed(1)}%]`
              },
              {
                value: d.damper.toFixed(2),
                name: '阻尼 ' + d.damper.toFixed(2) + ` [${(100 * d.damper / tp).toFixed(1)}%]`
              },
              { value: d.post.toFixed(2), name: '立柱 ' + d.post.toFixed(2) + `[${(100 * d.post / tp).toFixed(1)}%]` },
              {
                value: d.torqueTube.toFixed(2),
                name: '主梁 ' + d.torqueTube.toFixed(2) + ` [${(100 * d.torqueTube / tp).toFixed(1)}%]`
              },
              {
                value: d.purlin.toFixed(2),
                name: '檩条 ' + d.purlin.toFixed(2) + ` [${(100 * d.purlin / tp).toFixed(1)}%]`
              },
              {
                value: d.stampingParts.toFixed(2),
                name: '冲压件 ' + d.stampingParts.toFixed(2) + ` [${(100 * d.stampingParts / tp).toFixed(1)}%]`
              },
              {
                value: d.castingPart.toFixed(2),
                name: '铸造件 ' + d.castingPart.toFixed(2) + ` [${(100 * d.castingPart / tp).toFixed(1)}%]`
              },
              {
                value: d.fastners.toFixed(2),
                name: '紧固件 ' + d.fastners.toFixed(2) + ` [${(100 * d.fastners / tp).toFixed(1)}%]`
              },
              {
                value: d.others.toFixed(2),
                name: '其它 ' + d.others.toFixed(2) + ` [${(100 * d.others / tp).toFixed(1)}%]`
              }
            ]
          }
        ]
      }
      myChart.setOption(option)// 使用刚指定的配置项和数据显示图表。spareParts
    },

    //从后台获取图片的base64编码字符串
    fetchGetImgBase64(partNo) {
      fetch(process.env.VUE_APP_BASE_API + '/api/getImgBase64', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'token': getToken()// 添加Authorization字段，使用Bearer认证方式
        },
        body: partNo
      })
        .then(response => {
          // 确保服务器响应为成功状态码
          if (response.ok) {
            // 获取响应体中的JSON数据
            return response.json()
          } else {
            // 如果响应状态码不是2xx，抛出错误
            throw new Error('Something went wrong on server side.')
          }
        })
        .then(r => {
          this.imgObj[partNo] = r.data
        })
        .catch(error => {
          // 捕捉fetch过程中或处理响应时的错误
          console.error('Error:', error)
          return null
        })
    }
  },
  filters: {
    filterFix(value, n) {
      if (value != null && value > 0) {
        return value.toFixed(n)
      } else {
        return 0
      }
    },
    // filterFix(value){
    //   if (value != null && value>0){
    //     return value
    //   }
    //   else{
    //     return ""
    //   }
    // },
    filterCode(value) {
      if (value != null && value.indexOf('BP') > -1) {
        return value
      } else {
        return ''
      }
    }
  },

  props: {
    trackerObj: {},  //传入一个支架信息
    planPriceAdjust:{},  //传入所有调价信息
    spareParts:{},//传入备品备件率
    designer:'',
    myName:''
  },
  mounted() {
    console.log(this.trackerObj)
    console.log(this.planPriceAdjust)
    this.showEChartClass1()
    this.showEChartClass2()
    // this.showEChartClass3()

    this.imgObj = {
      'imgNotFound': 'data:image/png;base64,'
    }

  }

}


</script>

