          <td>{{ t.productCode}}</td>
          <td><a href="#" @click="showImage">{{ t.partNo }}</a></td>
          <td>{{ t.specification }}</td>
          <td>{{ t.material }}</td>
          <td>{{ t.length|filterFix(0) }}</td>
          <td>{{ t.amount }}</td>
          <td>{{ t.weightPerMater|filterFix(3) }}</td>
          <td>{{ t.unitWeight|filterFix(3) }}</td>
          <td>{{ t.totalWeight|filterFix(3) }}</td>
          <td>{{ t.unit }}</td>
          <td>{{ t.priceMethod }}</td>
          <td style="background-color: #ff440044">{{ t.costPrice|filterFix(2) }}</td>
          <td style="background-color: #ff440044">{{ t._unitPrice|filterFix(2) }}</td>
