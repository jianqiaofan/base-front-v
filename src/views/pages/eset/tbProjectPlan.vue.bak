    }
  },

  //方案的状态表，与项目的状态表完成不同

  //项目状态表有：
  //0-销售经理取项目号，项目正式立项、等待技术总监指派设计师;
  //1-设计师指定完成，等待设计师完成方案、提交内审和技术总监批准(此时方案状态可能为0,1,2,3);
  //2-项目设计配合完成(提交完成，此时工作流到销售部门)
  //3-反馈项目成果(已中标、未中标、或项目终止，或项目搁置)

  //方案状态表有：
  //0-已创建(方案一保存即创建，但未提交互相校核);
  //1-已提交给checker(check正在校对中);
  //2-check通过并转给技术总监审批(总监正在查看);
  //3-技术总监查看通过，转由销售总监调价(销售总监正在调价中，但未给销售经理);
  //4-销售总监查看通过，转由项目经理提交给业主;
  //5-已提交给业主;

  filters: {
    // 方案状态表过滤器
    planStatusFilter(status) {
      if (status === '0') {
        return ''
      } else if (status === '1') {
        return '正在校对中'
      } else if (status === '2') {
        return '等待技术总监审批'
      } else if (status === '3') {
        return '等待销售总监处理'
      } else if (status === '4') {
        return '已转交销售经理'
      } else if (status === '5') {
        return '已提交业主'
      } else {
        return ''
      }
    },
    projectStatusFilter(status) {
      if (status === '0') {
        return '已立项'
      } else if (status === '1') {
        return '设计中'
      } else if (status === '2') {
        return '已提交销售'
      } else if (status === '3') {
        return '已提交业主'
      } else {
        return ''
      }
    },
    linkFilter(str,n){
      if(typeof str !== 'string'){
        return undefined
      } else {
        if(str.trim().slice(0,4) === 'http'){
          return str.slice(0,n)
        } else {
          return undefined
        }
      }
    }
  },
  computed: {
    mydata(){
      return mydata
    },
    ...mapGetters([
      'name'
    ]),

    trackerTotalNum() {
      let n = 0
      this.trackersInfo.forEach((t) => {
        n += parseInt(t.trackerNum)
      })
      return n
    },

    //支架所占比例
    trackerRatio() {
      let r = []
      let totalNum = this.trackerTotalNum > 0 ? this.trackerTotalNum : 1  //支架总数
      this.trackersInfo.forEach((t) => {
        r.push(100 * parseInt(t.trackerNum) / totalNum)
      })
      return r
    },

    //单个支架的发电量
    singleTrackerPvCapacity() {
      let r = []
      this.trackersInfo.forEach((t) => {
        r.push(parseInt(t.pv_capacity) * parseInt(t.solar_num) / 1000)
      })
      return r
    },
    //单个种类支架的总发电量
    sortTrackerPvCapacity() {
      let r = []
      this.trackersInfo.forEach((t) => {
        r.push(parseInt(t.pv_capacity) * parseInt(t.solar_num) * parseInt(t.trackerNum) / 1000)
      })
      return r
    },
    //全部总容量
    trackerTotalWatt() {
      return this.sortTrackerPvCapacity.reduce((accumulator, currentValue) => {
        return accumulator + currentValue
      }, 0)
    },
    //气象站数量
    weatherStationNum() {
      let n = 0
      this.trackersInfo.forEach((t) => {
        n += parseInt(t.trackerNum)
      })
      return Math.ceil((n / 3))
    },
    weatherStationTotalPrice() {
      return this.weatherStationNum * this.weatherStationUnitPrice
    },

    showTable() {
      let tb = []
      for (let i = 0; i < this.my_projects.length; i++) {
        let a = {
          id: this.my_projects[i].id,
          name: this.my_projects[i].name,
          code: this.my_projects[i].code,
          site: this.my_projects[i].site,
          seller: this.my_projects[i].seller,
          designer: this.my_projects[i].designer,
          data_link: this.my_projects[i].data_link,
          planList: []
        }
        for (let j = 0; j < this.my_projects_plan.length; j++) {
          let c = '"' + a.code + '"'
          if (c.includes(this.my_projects_plan[j].project_code)) {
            let b = {
              plan_code: this.my_projects_plan[j].plan_code,
              project_code: this.my_projects_plan[j].project_code,
              designer: this.my_projects_plan[j].designer,
              plan_description: this.my_projects_plan[j].plan_description.replaceAll('"', ''),
              status: this.my_projects_plan[j].status,
              update_time: this.my_projects_plan[j].update_time,
              ifSubmit: this.my_projects_plan[j].status !== '0'
            }
            a.planList.push(b)
          }
        }
        tb.push(a)
      }
      return tb
    },
    showCheckTable() {
      let tb = []
      for (let i = 0; i < this.my_check_projects_plan.length; i++) {
        let a = {
          plan_code: this.my_check_projects_plan[i].plan_code,
          project_code: this.my_check_projects_plan[i].project_code,
          project_name: this.my_check_projects_plan[i].project_name,
          plan_description: this.my_check_projects_plan[i].plan_description,
          designer: this.my_check_projects_plan[i].designer,
          checker: this.my_check_projects_plan[i].checker,
          data_link: this.my_check_projects_plan[i].data_link,
          status: this.my_check_projects_plan[i].status,
          update_time: this.my_check_projects_plan[i].update_time
        }
        tb.push(a)
      }
      console.log("tbtbtbtb=",tb)
      return tb
    },

    showApprovalTable() {

      let tb = []
      for (let i = 0; i < this.approval_plan.length; i++) {
        let a = {
          plan_code: this.approval_plan[i].plan_code,
          project_code: this.approval_plan[i].project_code,
          project_name: this.approval_plan[i].project_name,
          plan_description: this.approval_plan[i].plan_description,
          designer: this.approval_plan[i].designer,
          checker: this.approval_plan[i].checker,
          technical_director: this.approval_plan[i].technical_director,
          data_link: this.approval_plan[i].data_link,
          status: this.approval_plan[i].status,
          update_time: this.approval_plan[i].update_time
        }
        tb.push(a)
      }
      return tb
    },

  },
  // 生命周期函数：内存准备完毕，页面尚未渲染
  created() {
    this.fetchMyProjectData()  //获取自己负责的项目列表
    this.fetchMyProjectPlanData()  //获取自己负责的项目方案列表
    this.fetchMyCheckProjectPlanData()  //获取自己负责校对的项目方案列表
    this.fetchApprovalPlanData()   //如果是技术总监，则获取等待审批的列表
  },

  // 生命周期函数：内存准备完毕，页面渲染成功
  mounted() {
    // this.findAllTbProjectData()  //获取全部项目信息
    this.aaaa()
  },
  methods: {
    aaaa(){
      var tag = document.getElementsByTagName("a");
      for (let i = 0; i < tag.length; i++) {
        tag[i].onclick = function(event) {
          event.preventDefault();
        };
      }
    },
    checkPass(planCode) {
      this.thePlanCode = planCode
      this.dialogCheckPassVisible = true
    },
    checkReject(planCode) {
      this.thePlanCode = planCode
      this.dialogCheckRejectVisible = true
    },
    approvalPass(planCode) {
      this.thePlanCode = planCode
      this.dialogApprovalPassVisible = true
    },
    approvalReject(planCode) {
      this.thePlanCode = planCode
      this.dialogApprovalRejectVisible = true
    },

    makeSureCheckPass() {
      console.log("$$$",process.env.VUE_APP_BASE_API + '/api/planCheckPass')
      fetch(process.env.VUE_APP_BASE_API + '/api/planCheckPass', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'token': getToken()// 添加Authorization字段，使用Bearer认证方式
        },
        body: JSON.stringify(
          this.thePlanCode
          + 'XxXxX' + this.check_pass_description
          + 'XxXxX' + this.name
        )
      })
        .then(response => {
          // 确保服务器响应为成功状态码
          if (response.ok) {
            this.fetchMyProjectData()  //获取自己负责的项目列表
            this.fetchMyProjectPlanData()  //获取自己负责的项目方案列表
