<template>
  <div class="app-container">
    <Myduty></Myduty>
    <el-divider></el-divider>
    <div v-if="approval_plan.length >0 ">
      <h3 id="maodian">待审批的方案</h3>
      <table style="width: 1500px">
        <thead>
        <tr>
          <td style="width: 40px">序号</td>
          <td style="width: 180px">项目名称</td>
          <td style="width: 100px">项目编号</td>
          <td style="width: 180px">方案名称</td>
          <td style="width: 100px">设计师</td>
          <td style="width: 100px">校核人</td>
          <td style="width: 100px">方案状态</td>
          <td style="width: 200px">提交资料链接</td>
          <td style="width: 160px">更新时间</td>
          <td style="width: 160px">要求完成时间</td>
          <td style="width: 120px">操作</td>
        </tr>
        </thead>
        <tr v-for="(plan,items) in showApprovalTable" v-if="plan.technical_director === name" :key="plan.plan_code">
          <td>{{ items + 1 }}</td>

          <td style="text-align: left;padding-left: 10px">{{ plan.project_name }}</td>
          <td style="text-align: left;padding-left: 10px">{{ plan.project_code }}</td>

          <td style="text-align: left;padding-left: 10px">
            <button class="check-bom"  @click="editPlan(plan.plan_code,plan.status,plan.designer,true)">{{ plan.plan_description }}</button>
          </td>

          <td>{{ plan.designer }}</td>
          <td>{{ plan.checker }}</td>

          <td v-if="plan.status==='2'"><span style="color: orangered">请尽快处理</span></td>
          <td v-else>{{ plan.status|planStatusFilter }}</td>

          <td>
            <el-link :href="plan.data_link" target="_blank">{{ plan.data_link|linkFilter(36) }}</el-link>
          </td>

          <td>{{ plan.update_time }}</td>
          <td>{{ plan.required_completion_time}}</td>
          <td>
            <button @click="approvalPass(plan.plan_code)" :disabled="plan.status!=='2'">通过</button>
            <button @click="approvalReject(plan.plan_code)" :disabled="plan.status!=='2'">退回</button>
          </td>
        </tr>
      </table>
      <el-divider></el-divider>
    </div>

    <div v-if="showTable.length >0">
      <h3 id="maodian1">我的项目方案</h3>
      <table style="width: 1500px">
        <thead>
        <tr style="height: 60px">
          <td style="width: 300px"><h3>项目名称</h3></td>
          <td ><h3>方案明细</h3></td>
        </tr>
        </thead>
        <tbody>
        <tr v-for="project in showTable" :key="project.id" style="height: 40px">
          <td style="text-align: left;padding-left: 10px">
            <span v-show="!project.name.includes('临时保存')">项目编号：{{ project.code }}</span><br>
            项目名称：<router-link class="link-item" :to="`/tbTrackbom?pcode=${project.code}&pname=${project.name}`">{{ project.name }}</router-link><br>
            <span v-show="!project.name.includes('临时保存')">销售经理：{{ project.seller }}</span><br>
            <span v-show="!project.name.includes('临时保存')">
            提资链接：<el-link type="primary" :href="project.data_link" target="_blank">{{ project.data_link|linkFilter(36) }}</el-link>
            </span>
          </td>
          <td>
            <div v-if="project.planList.length > 0">
              <table>
                <thead>
                <tr>
                  <td style="width: 60px">序号</td>
                  <td style="width: 280px;">方案信息</td>
                  <td style="width: 150px">状态</td>
                  <td style="width: 160px">更新时间</td>
                  <td style="width: 160px">操作</td>
                </tr>
                </thead>
                <tr v-for="(plan,items) in project.planList" :key="plan.plan_code">
                  <td>
                    <input type="checkbox" :id="project.code+'_'+plan.plan_code" :disabled="plan.ifSubmit">&nbsp;&nbsp;&nbsp;&nbsp;
                    {{ items + 1 }}
                  </td>
                  <td style="text-align: left;padding-left: 10px">
                    <button class="check-bom" @click="editPlan(plan.plan_code,plan.status,plan.designer,true)">{{ plan.plan_description }}</button>
                  </td>

                  <td>{{ plan.status | planStatusFilter }}</td>

                  <td>{{ plan.update_time }}</td>
                  <td>
                    <el-button type="primary" size="mini"
                               @click="editPlan(plan.plan_code,plan.status,plan.designer,false)"
                    >
                      编 辑
                    </el-button>
                    <el-button type="danger" size="mini"
                               @click="showDeletePlan(plan.plan_code,plan.status,plan.designer)"
                    >
                      删 除
                    </el-button>
                  </td>

                </tr>
                <tr v-show="!project.name.includes('临时保存')">
                  <td colspan="3" style="text-align: left">请选择后再提交</td>
                  <td>
                    <el-button type="text" @click="showDialog(project.name,project.code)">提交校审</el-button>
                  </td>
                </tr>
              </table>
            </div>
            <div v-if="project.planList.length === 0">
              <span style="color: red">暂无方案</span>
            </div>
          </td>

        </tr>
        </tbody>

      </table>
      <el-divider></el-divider>
    </div>

    <div v-if="showCheckTable.length > 0">
      <h3 id="maodian2">我的校核</h3>
      <table style="width: 1500px">
        <thead>
        <tr>
          <td style="width: 60px">序号</td>
          <td style="width: 180px">项目名称</td>
          <td style="width: 100px">项目编号</td>
          <td style="width: 280px;">方案信息</td>
          <td style="width: 100px">设计师</td>
          <td style="width: 100px">方案状态</td>
          <td style="width: 200px">提交资料链接</td>
          <td style="width: 160px">更新时间</td>
          <td style="width: 160px">要求完成时间</td>
          <td style="width: 120px">操作</td>
        </tr>
        </thead>
        <tr v-for="(plan,items) in showCheckTable" :key="plan.plan_code">
          <td>{{ items + 1 }}</td>

          <td style="text-align: left;padding-left: 10px">{{ plan.project_name }}</td>
          <td style="text-align: left;padding-left: 10px">{{ plan.project_code }}</td>
          <td style="text-align: left;padding-left: 10px">
            <button class="check-bom" @click="editPlan(plan.plan_code,plan.status,plan.designer,true)">{{ plan.plan_description }}</button>
          </td>

          <td>{{ plan.designer }}</td>

          <td v-if="plan.status==='0'"><span style="color: greenyellow">已退回</span></td>
          <td v-else-if="plan.status==='1'"><span style="color: orangered">请尽快处理</span></td>
          <td v-else>{{ plan.status|planStatusFilter }}</td>

          <td>
            <el-link :href="plan.data_link" target="_blank">{{ plan.data_link|linkFilter(36) }}</el-link>
          </td>

          <td>{{ plan.update_time }}</td>
          <td>{{ plan.required_completion_time }}</td>
          <td>
            <button @click="checkPass(plan.plan_code)" :disabled="plan.status!=='1'">通过</button>
            <button @click="checkReject(plan.plan_code)" :disabled="plan.status!=='1'">退回</button>
          </td>
        </tr>
      </table>
      <el-divider></el-divider>
    </div>

    <!--    提交校核表单-->
    <el-dialog title="提交校核" :visible.sync="dialogVisible" width="40%" :close-on-click-modal="false">
      <el-form ref="dataForm" label-width="100px" size="small"
               style="padding-right: 40px;"
      >
        <el-form-item label="项目名称">{{ theProjectName }}</el-form-item>
        <el-form-item label="校核人" prop="whoCheck">
          <el-select v-model="whoCheck" placeholder="请指定校核人">
            <el-option
              v-for="item in mydata.select_option.designer" :key="item.value" :label="item.label" :value="item.value"
            >
            </el-option>
          </el-select>
        </el-form-item>

        <el-form-item label="补充说明" prop="code">
          <el-input type="textarea" :rows="2" placeholder="请输入内容(100字以内)" v-model="theDescription">
          </el-input>
        </el-form-item>
        <el-form-item label="提交方案" prop="name">
          <el-input v-model="theSubmitPlans" :disabled="true"/>
        </el-form-item>


      </el-form>

      <span slot="footer" class="dialog-footer">
        <el-button @click="dialogVisible = false" size="small" icon="el-icon-refresh-right">取 消</el-button>
        <el-button type="primary" icon="el-icon-check" @click="submitCheck()" size="small">确 定</el-button>
      </span>
    </el-dialog>

    <el-dialog title="方案明细" :visible.sync="checkDialogVisible" width="90%" :close-on-click-modal="false">
      <!--      <el-button @click="drawer = true" type="primary" style="margin-left: 16px;">-->
      <!--        点我打开-->
      <!--      </el-button>-->
      <h1>校核信息</h1>
      <!--备品备件率表-->
      <table>
        <caption style="text-align: left;">
          <label>备品备件率%</label>
        </caption>
        <thead>
        <tr>
          <td style="width:80px">立柱</td>
          <td style="width:80px">主梁</td>
          <td style="width:80px">檩条</td>
          <td style="width:80px">紧固件</td>
          <td style="width:80px">标准件</td>
          <td style="width:80px">电器配件</td>
          <td style="width:80px">其它</td>
        </tr>
        </thead>
        <tbody>
        <tr>
          <td>{{ spareParts.post }}</td>
          <td>{{ spareParts.beam }}</td>
          <td>{{ spareParts.purlin }}</td>
          <td>{{ spareParts.fasten }}</td>
          <td>{{ spareParts.standard }}</td>
          <td>{{ spareParts.electricalMechanical }}</td>
          <td>{{ spareParts.other }}</td>
        </tr>
        </tbody>
      </table>
      <el-divider></el-divider>

      <!--    全部要人工输入的内容-->
      <table>
        <caption style="text-align: left;">
          <label>项目信息输入(需要手工输入)</label>
        </caption>
        <thead>
        <tr>
          <td>Tracker<br>Name</td>
          <td style="width: 50px">组件<br>套数</td>
          <td style="width: 50px">组件<br>容量</td>
          <td style="width: 80px">产品系列</td>
          <td style="width: 80px">供电方式</td>
          <td style="width: 80px">防腐<br>等级</td>
          <td style="width: 80px">立柱<br>防腐</td>
          <td style="width: 80px">主梁<br>防腐</td>
          <td style="width: 80px">檩条<br>防腐</td>
          <td style="width: 60px">主梁<br>品牌</td>
          <td style="width: 60px">檩条<br>品牌</td>
          <td style="width: 80px">桩基类别</td>
          <td style="width: 80px">桩参数</td>
          <td style="width: 80px">减速机</td>
          <td style="width: 120px">减速机罩</td>
          <td style="width: 80px">阻尼立柱</td>
          <td style="width: 80px">阻尼型号</td>
          <td style="width: 80px">梁柱表</td>
        </tr>
        </thead>
        <tbody>
        <!--      综合输入-->
        <tr v-if="trackersInfo.length>0">
          <td colspan="15">以下为单个支架进行输入</td>
        </tr>
        </tbody>

        <!--      各支架单独输入-->
        <tbody v-for="t in trackersInfo" :key="t.id">

        <tr :style="{backgroundColor:t.rowColor}">
          <td>{{ t.trackBrifeName }}</td>
          <td>{{ t.trackerNum }}</td>
          <td>{{ t.pv_capacity }}</td>
          <td>{{ t.product_system }}</td>
          <td>{{ t.power_supply }}</td>
          <td>{{ t.corrosion_proofing_grade }}</td>
          <td>{{ t.post_galvanizin_thickness }}</td>
          <td>{{ t.beam_galvanizin_thickness }}</td>
          <td>{{ t.purlin_galvanizin_thickness }}</td>
          <td>{{ t.beam_brand }}</td>
          <td>{{ t.purlin_brand }}</td>
          <td></td>
          <td></td>
          <td>{{ t.slew_drive_inch }}</td>
          <td>{{ t.slew_cover_if_need?'有':'无' }}</td>
          <td>{{ t.dumper_num }}</td>
          <td>{{ t.dumper_type }}
            <td>
              <button @click="t.showPostBeamTable=!t.showPostBeamTable">展开/隐藏</button>
            </td>
          </td>
          <td></td>
        </tr>
        <tr v-show="t.showPostBeamTable">
          <td>{{ t.trackBrifeName }}</td>
          <td colspan="10">

            <!--立柱明细表-->
            <div>
              <table style="width: 700px;">
                <thead>
                <tr>
                  <td style="text-align: center;">位置</td>
                  <td style="text-align: center;">驱动</td>
                  <td style="text-align: center;">截面</td>
                  <td style="text-align: center;">材质</td>
                  <td style="text-align: center;">高度</td>
                  <td style="text-align: center;">桩类型</td>
                  <td style="text-align: center;">桩详细参数</td>
                </tr>
                </thead>

                <tbody>
                <tr v-for="p in t.post_info_lst" :key="t.position">
                  <td style="text-align: center;width:80px;">{{ p.position }}</td>
                  <td style="text-align: center;width:80px;">{{ p.category }}</td>
                  <td style="text-align: center;width:80px;">{{ p.section }}</td>
                  <td style="text-align: center;width:80px;">{{ p.material }}</td>
                  <td style="text-align: center;width:60px;">{{ p.height }}</td>
                  <td style="text-align: center;width:80px;">{{ p.pile_type }}</td>
                  <td style="text-align: left;">{{ p.pile_desc }}</td>
                </tr>
                </tbody>
              </table>
            </div>   <!--立柱明细表-->
          </td>
          <td colspan="8">
            <!--主梁明细表-->
            <div style="vertical-align: top">
              <table style="width: 600px;">
                <thead>
                <tr>
                  <td>起点</td>
                  <td>终点</td>
                  <td>截面</td>
                  <td>材质</td>
                  <td>长度</td>
                  <td>类别</td>
                </tr>
                </thead>
                <tbody>
                <tr v-for="b in t.beam_info_lst" :key="b.start">
                  <td style="width:80px;">{{ b.start }}</td>
                  <td style="width:80px;">{{ b.end }}</td>
                  <td style="width:166px;">{{ b.section }}</td>
                  <td style="width:80px;">{{ b.material }}</td>
                  <td style="width:60px;">{{ b.length }}</td>
                  <td style="text-align: center;">{{ b.category }}</td>
                </tr>
                </tbody>
              </table>
            </div>   <!--主梁明细表-->
<!--            <button @click="printTrackObj(t)">打印输入数据</button>-->
          </td>
        </tr>
        </tbody>

      </table>
      <el-divider></el-divider>

      <!--    檩条输入-->
      <table>
        <caption style="text-align: left;">
          <label>项目信息输入(檩条)</label>
        </caption>
        <thead>
        <tr>
          <td>Tracker Name</td>
          <td>檩条总根数</td>
          <td style="width: 500px">截面型号/材质/长度/数量</td>
        </tr>
        </thead>
        <tbody>

        <!--单个支架檩条单独输入-->
        <tr tr v-for="t in trackersInfo" :key="t.id" :style="{backgroundColor:t.rowColor}">
          <td>{{ t.trackBrifeName }}</td>
          <!--檩条总根数-->
          <td>{{ t.purlinCount }}</td>
          <td style="text-align: left">
            <div v-for="purlin in t.purlin_info_lst " :key="purlin.id">
              <tr>
                <td style="width: 100px;">{{ purlin.section }}</td>
                <td style="width: 100px;">{{ purlin.length }}</td>
                <td style="width: 100px;">{{ purlin.material }}</td>
                <td style="width: 100px;">{{ purlin.amount }}</td>
              </tr>
            </div>
          </td>
        </tr>

        </tbody>
      </table>
      <el-divider></el-divider>

      <!--    主要从计算文件中导出，少量需要手工更正的内容表-->
      <table>
        <caption style="text-align: left;">
          <label>项目信息输入(主要从计算文件中导出，少量需要手工更正的内容表)</label>
        </caption>
        <thead>
        <tr>
          <td>Tracker Name</td>
          <td>组件结构</td>
          <td style="width: 160px">组件排布</td>
          <td>组件数量</td>
          <td>组件串数</td>
          <td>单板长度</td>
          <td>单板宽度</td>
          <td>单板厚度</td>
          <td>驱动柱数量</td>
          <td>组件最小离地</td>
          <td>指定柱距</td>
          <td>是否通铺</td>
        </tr>
        </thead>
        <tbody>

        <tr v-for="t in trackersInfo" :key="t.id">
          <td>{{ t.trackBrifeName }}</td>
          <td>{{ t.product_system }}</td>
          <td>{{ t.solar_list }}</td>
          <td>{{ t.solar_num }}</td>
          <td>{{ t.pvStringNum }}</td>
          <td>{{ t.pv_length }}</td>
          <td>{{ t.pv_width }}</td>
          <td>{{ t.pv_thickness }}</td>
          <td>{{ t.slew_count }}</td>
          <td>{{ t.h_min }}</td>
          <td>{{ t.dis }}</td>
          <td>{{ t.pv_iftp }}</td>
        </tr>

        </tbody>
      </table>

      <el-divider></el-divider>

      <table>
        <caption style="text-align: left;">
          <label>计算结果(sum)</label>
        </caption>
        <thead>
        <tr>
          <td>序号</td>
          <td>支架名称</td>
          <td>操作查看</td>
          <td colspan="2">支架数量(套)</td>
          <td colspan="2">容量(kW)</td>
          <!--不含备品备件-->
          <td colspan="3">不含备件</td>
          <!--含备品备件-->
          <td colspan="3">含备件</td>
        </tr>
        <tr>
          <td>No.</td>
          <td style="width: 100px;">Tracker Name</td>
          <td>Results</td>

          <td style="width: 80px;">支架</td>
          <td style="width: 80px;">占比</td>
          <td style="width: 80px;">单套</td>
          <td style="width: 80px;">总容量</td>
          <!--不含备品备件-->
          <td style="width: 80px;">单套价格</td>
          <td style="width: 80px;">总价格</td>
          <td style="width: 80px;">元/W</td>
          <!--含备品备件-->
          <td style="width: 80px;">单套价格</td>
          <td style="width: 80px;">总价格</td>
          <td style="width: 80px;">元/W</td>

        </tr>
        </thead>
        <tbody>
        <tr v-for="(t,item) in trackersInfo" :key="t.id">
          <td>{{ item + 1 }}</td>
          <td>{{ t.trackBrifeName }}</td>
          <td>
            <el-button @click="drawerShowResult(t.id,item)" type="primary" size="mini" :disabled="!t.ifCalculated">查看结果
            </el-button>
          </td>
          <td>{{ t.trackerNum }}</td>
          <td>{{ trackerRatio[item].toFixed(2) }}%</td>
          <!--单套容量-->
          <td>{{ singleTrackerPvCapacity[item] }}</td>
          <!--总容量-->
          <td>{{ sortTrackerPvCapacity[item] }}</td>

          <!--        不含备件单价总价-->
          <td>{{ trackerPrice[item] }}</td>
          <td>{{ sortTrackerPrice[item] }}</td>
          <td>{{ pricePerWattWithSpareParts[item] }}</td>
          <!--        含备件单价总价-->
          <!--        <td>{{ trackerPrice[item] }}</td>-->
          <td>{{ trackerPriceWithSpareParts[item] }}</td>
          <td>{{ sortTrackerPriceWithSpareParts[item] }}</td>
          <td>{{ pricePerWattWithSpareParts[item] }}</td>
          <!--        <td></td>-->
        </tr>
        <tr>
          <td>不含气象站总计</td>
          <td></td>
          <td>全部数量</td>
          <td>{{ this.trackerTotalNum }}</td>
          <td>100%</td>
          <td>全部容量</td>
          <td>{{ this.trackerTotalWatt }}</td>
          <td>总计</td>
          <td>{{ totalTrackerPrice }}</td>
          <td></td>
          <td>总计</td>
          <td>{{ totalTrackerPriceWithSpareParts }}</td>
          <td></td>
        </tr>
        <tr>
          <td>含气象站总计</td>
          <td></td>
          <td></td>
          <td></td>
          <td></td>
          <td></td>
          <td></td>
          <td>总计</td>
          <td>{{ (totalTrackerPrice + weatherStationTotalPrice).toFixed(2) }}</td>
          <td></td>
          <td>总计</td>
          <td>{{ (totalTrackerPriceWithSpareParts + weatherStationTotalPrice).toFixed(2) }}</td>
          <td></td>
        </tr>

        </tbody>
      </table>
      <!--      {{jsonObject}}-->
      <span slot="footer" class="dialog-footer">
        <el-button @click="checkDialogVisible = false" size="small" icon="el-icon-refresh-right">取 消</el-button>
        <!--        <el-button type="primary" icon="el-icon-check" @click="submitCheck()" size="small">确 定</el-button>-->
      </span>
    </el-dialog>


    <!--    校核通过驳回对话框=====================================================-->
    <el-dialog title="确认校核通过对话框" :visible.sync="dialogCheckPassVisible" width="40%"
               :close-on-click-modal="false"
    >
      <el-form ref="dataForm" :rules="rules" label-width="100px" size="small"
               style="padding-right: 40px;"
      >
        <el-form-item label="请补充说明(如果有)" prop="code">
          <el-input type="textarea" :rows="4" placeholder="请输入内容(500字以内)" v-model="check_pass_description">
          </el-input>
        </el-form-item>
      </el-form>
      <span slot="footer" class="dialog-footer">
        <el-button @click="dialogCheckPassVisible = false" size="small" icon="el-icon-refresh-right">取 消</el-button>
        <el-button type="primary" icon="el-icon-check" @click="makeSureCheckPass()" size="small">确认通过</el-button>
      </span>
    </el-dialog>
    <!--    校核驳回对话框=====================================================-->
