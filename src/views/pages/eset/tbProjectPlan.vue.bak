    showPlanDetail(planCode) {
      fetch(process.env.VUE_APP_BASE_API + '/api/findPlanDetail', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'token': getToken()// 添加Authorization字段，使用Bearer认证方式
        },
        body: planCode
      })
        .then(response => {
          // 确保服务器响应为成功状态码
          if (response.ok) {
            // 获取响应体中的JSON数据
            return response.json()
          } else {
            // 如果响应状态码不是2xx，抛出错误
            throw new Error('Something went wrong on server side.')
          }
        })
        .then(r => {
          this.thisStr = r.data
          this.jsonObject = JSON.parse(this.thisStr)
          this.trackersInfo = this.jsonObject.trackersInfo
          this.spareParts = this.jsonObject.spareParts
          this.checkDialogVisible = true
          this.refreshAfterCaclu()
          // console.log("666666666666",r.data)
        })
        .catch(error => {
          // 捕捉fetch过程中或处理响应时的错误
          console.error('Error:', error)
        })
    },

    //弹出提交校核对话框
    showDialog(projectName, projectCode) {
      this.theProjectName = projectName
      this.theProjectCode = projectCode
      const checkboxes = document.querySelectorAll('input[type="checkbox"]')
      let checkboxIds = []

      checkboxes.forEach(checkbox => {
        // checkboxIds.push(checkbox.id);
        if (checkbox.id.includes(projectCode) && checkbox.checked) {
          checkboxIds.push(checkbox.id.replace(projectCode + '_', ''))
        }
      })
      if (checkboxIds.length === 0) {
        alert(this.theProjectName + '没有方案被选中，请重新选择后提交!')
        return
      }
      this.theSubmitPlans = checkboxIds.join(',')
      this.dialogVisible = true
    },
    editPlan(planCode, status, designer, ifOnlyCheck) {
      if (!ifOnlyCheck && designer !== this.name) {
        alert('只允许编辑自己的方案,本次操作无法继续!')
        return
      }
      if (!ifOnlyCheck && status !== '0') {
        alert('本方案当前处于校审中,无法删除。如需删除，请联系后续节点退回!')
        return
      }
      this.$router.push({
        path:'tbTrackbom',
        query:{
          planCode: planCode,
          edt:ifOnlyCheck
        }
      })
    },

    showDeletePlan(planCode, status, designer) {
      if (designer !== this.name) {
        alert('只允许删除自己的方案,本次操作无法继续!')
        return
      }
      if (status !== '0') {
        alert('本方案当前处于校审中,无法删除。如需删除，请联系后续节点退回!')
        return
      }
      this.$confirm('此操作将永久删除该记录, 是否继续?', '提示', {
        confirmButtonText: '确定',
        cancelButtonText: '取消',
        type: 'warning'
      }).then(() => { // promise
        // 操作确定，远程调用ajax
        fetch(process.env.VUE_APP_BASE_API + '/api/deteleProjectPlan', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'token': getToken()// 添加Authorization字段，使用Bearer认证方式
          },
          body: planCode
        })
          .then(response => {
            // 确保服务器响应为成功状态码
            if (response.ok) {
              // 获取响应体中的JSON数据
              return response.json()
            } else {
              // 如果响应状态码不是2xx，抛出错误
              throw new Error('Something went wrong on server side.')
            }
          })
          .then(r => {
            alert('删除成功')
            this.fetchMyProjectData()  //获取自己负责的项目列表
            this.fetchMyProjectPlanData()  //获取自己负责的项目方案列表
          })
          .catch(error => {
            // 捕捉fetch过程中或处理响应时的错误
            console.error('Error:', error)
          })
      }).then((response) => {
        this.fetchData(this.page)
        this.$message.success(response.message || '删除成功')
      }).catch(() => {
        this.$message.info('取消删除')
      })
    },
    //计算完成后,刷新数据到页面
    refreshAfterCaclu() {
      let t = this.trackersInfo
      //如果之前有数据,这里要清空
      this.trackerPriceClassfy1 = []
      this.trackerPrice = []
      this.trackerPriceWithSpareParts = []
      this.sortTrackerPrice = []
      this.sortTrackerPriceWithSpareParts = []
      this.pricePerWatt = []
      this.pricePerWattWithSpareParts = []
      this.totalTrackerPrice = 0
      this.totalTrackerPriceWithSpareParts = 0

      //按立柱，主梁，檩条，标准件，紧固件，电气&机械,其它等分类方式维度计算
      let price = 0  //不含备件单个支架总价格
      let priceWithSpareParts = 0  //含备件单个支架总价格
      for (let i = 0; i < t.length; i++) {
        let trackerNum = this.trackersInfo[i].trackerNum * 1
        let watt = parseInt(this.trackersInfo[i].pv_capacity) * parseInt(this.trackersInfo[i].solar_num)  //每个支架的总功率
        if (watt === 0) {
          watt = 1
        }  //防止被0除错误
        let bom = t[i].resultList.bom1.concat(t[i].resultList.bom2).concat(t[i].resultList.bom3)
        let price_post = 0
        let price_beam = 0
        let price_purlin = 0
        let price_standard = 0
        let price_fasten = 0
        let price_electricalMechanical = 0
        let price_other = 0

        for (let j = 0; j < bom.length; j++) {
          if (bom[j].productCategory === 'H型钢') {
            price_post = price_post + bom[j].totalPrice * 1
          } else if (bom[j].productCategory === '主梁') {
            price_beam = price_beam + bom[j].totalPrice * 1
          } else if (bom[j].productCategory === '檩条') {
            price_purlin = price_purlin + bom[j].totalPrice * 1
          } else if (bom[j].productCategory === '标准件') {
            price_standard = price_standard + bom[j].totalPrice * 1
          } else if (bom[j].productCategory === '紧固件') {
            price_fasten = price_fasten + bom[j].totalPrice * 1
          } else if (bom[j].productCategory === '电气&机械') {
            price_electricalMechanical = price_electricalMechanical + bom[j].totalPrice * 1
          } else {
            price_other = price_other + bom[j].totalPrice * 1
          }
        }
        price = price_post + price_beam + price_purlin + price_standard
          + price_fasten + price_electricalMechanical + price_other
        this.trackerPrice.push(price.toFixed(2))  //不含备品备件单个总价
        this.pricePerWatt.push((price / watt).toFixed(4))
        this.sortTrackerPrice.push((price * trackerNum).toFixed(2))//不含备品备件该种支架全部总价

        this.trackerPriceClassfy1.push({
          post: price_post,
          beam: price_beam,
          purlin: price_purlin,
          standard: price_standard,
          fasten: price_fasten,
          electricalMechanical: price_electricalMechanical,
          other: price_other
        })
        priceWithSpareParts =
          price_post * (0.01 * this.spareParts.post + 1) +
          price_beam * (0.01 * this.spareParts.beam + 1) +
          price_purlin * (0.01 * this.spareParts.purlin + 1) +
          price_standard * (0.01 * this.spareParts.standard + 1) +
          price_fasten * (0.01 * this.spareParts.fasten + 1) +
          price_electricalMechanical * (0.01 * this.spareParts.electricalMechanical + 1) +
          price_other * (0.01 * this.spareParts.other + 1)
        this.trackerPriceWithSpareParts.push(priceWithSpareParts.toFixed(2))  //含备品备件单个支架总价
        this.pricePerWattWithSpareParts.push((priceWithSpareParts / watt).toFixed(4))
        this.sortTrackerPriceWithSpareParts.push((priceWithSpareParts * trackerNum).toFixed(2))//含备品备件该种支架全部总价

      }

      this.totalTrackerPrice =
        this.sortTrackerPrice.reduce((accumulator, currentValue) => accumulator * 1 + currentValue * 1, 0)
      this.totalTrackerPriceWithSpareParts =
        this.sortTrackerPriceWithSpareParts.reduce((accumulator, currentValue) => accumulator * 1 + currentValue * 1, 0)

    },
    handleDrawerClose(done) {
      this.$confirm('确认关闭？')
        .then(_ => {
          done()
        })
        .catch(_ => {
        })
    },
    drawerShowResult(tid, item) {
      this.refreshAfterCaclu()
      // console.log('1@@', this.trackersInfo[item])
      // console.log('2@@', this.sortTrackerPrice[item])
      // console.log('3@@', this.trackerPriceClassfy1[item])
      this.drawer = true
      let t = {}
      for (let i = 0; i < this.trackersInfo.length; i++) {
        if (this.trackersInfo[i].id === tid) {
          t = this.trackersInfo[i]
        }
      }
      this.drawerTitle = (item + 1) + ' ' + t.trackBrifeName + ' 计算结果'
      this.drawerResultData = {
        trackBrifeName: t.trackBrifeName,
        trackerPrice: this.trackerPrice[item],
        trackerPriceWithSpareParts: this.trackerPriceWithSpareParts[item],
        trackerPriceClassfy1: this.trackerPriceClassfy1[item],
        spareParts: this.spareParts,
        bom1: t.resultList.bom1,
        bom2: t.resultList.bom2,
        bom3: t.resultList.bom3,
        bomErr: t.resultList.bomErr
      }
    },
    submitCheck() {
      if (this.theSubmitPlans.length <= 1) {
        alert('没有方案被选中，请重新选择后提交!')
        return
      }
      if (this.whoCheck.length <= 1) {
        alert('没有选择合适的校核人，请重新选择后提交!')
        return
      }
      fetch(process.env.VUE_APP_BASE_API + '/api/submitPlanCheck', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'token': getToken()// 添加Authorization字段，使用Bearer认证方式
        },
        body: JSON.stringify(
          this.whoCheck
          + 'XxXxX' + this.theSubmitPlans
          + 'XxXxX' + this.theDescription
          + 'XxXxX' + this.theProjectCode
          + 'XxXxX' + this.name
        )
      })
        .then(response => {
          // 确保服务器响应为成功状态码
          if (response.ok) {
            // 获取响应体中的JSON数据
            return response.json()
          } else {
            // 如果响应状态码不是2xx，抛出错误
            throw new Error('Something went wrong on server side.')
          }
        })
        .then(r => {
          this.dialogVisible = false
          this.fetchMyProjectPlanData()

        })
        .catch(error => {
          // 捕捉fetch过程中或处理响应时的错误
          console.error('Error:', error)
        })
      alert('方案已提交给 '+this.whoCheck+' 进行内部校核，请线下通知 '+this.whoCheck+',并耐心等待校核结果！')


    },
    //获取本人项目信息和编号
    fetchMyProjectData() {
      fetch(process.env.VUE_APP_BASE_API + '/api/findMyProject', {
