# 环境变量示例（无真实密钥）
# 用法：按环境复制并重命名，再修改为你的实际配置
#   开发：cp .env.example .env.development
#   预发：cp .env.example .env.staging
#   生产：cp .env.example .env.production
#
# Windows PowerShell 示例：
#   Copy-Item .env.example .env.development

# 环境标识：development | staging | production
ENV = 'development'

# 后端 API 根地址（Vue CLI 会注入为 process.env.VUE_APP_BASE_API）
# 开发常用本地或代理前缀，例如：
#   http://localhost:5240
#   /dev-api
VUE_APP_BASE_API = 'http://localhost:5240'

# 预发示例（复制为 .env.staging 时使用）：
# NODE_ENV = production
# ENV = 'staging'
# VUE_APP_BASE_API = '/stage-api'

# 生产示例（复制为 .env.production 时使用）：
# ENV = 'production'
# VUE_APP_BASE_API = 'https://your-api.example.com/api'
